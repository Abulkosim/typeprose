DATABASE_URL=postgres://prosetype:prosetype@localhost:5432/prosetype
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Account-claim email (§10.3). Leave unset in dev — the API logs the magic link
# instead of sending it. To send for real, set both (from must be on a Resend-
# verified domain):
# RESEND_API_KEY=re_...
# EMAIL_FROM=prosetype <no-reply@prosetype.app>
