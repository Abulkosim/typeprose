{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=../../.env src/server.ts",
    "start": "node --env-file-if-exists=../../.env src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "@typeprose/engine": "workspace:*",
    "@typeprose/schema": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  }
}
