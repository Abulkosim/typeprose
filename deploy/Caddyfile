# Caddy serves the static SPA and reverse-proxies the API (plan §12).
# SITE_ADDRESS is the public hostname; Caddy auto-provisions TLS for a real
# domain (use `localhost` or `:80` locally). The /api prefix is preserved -
# the API mounts its routes under /api/v1.
{$SITE_ADDRESS:localhost} {
	encode gzip

	@api path /api/*
	handle @api {
		reverse_proxy api:3001
	}

	handle {
		root * /srv
		# Browsers cap sw.js caching at 24h; no-cache makes a deploy's new
		# worker propagate on the next navigation instead.
		header /sw.js Cache-Control no-cache
		try_files {path} /index.html
		file_server
	}
}
