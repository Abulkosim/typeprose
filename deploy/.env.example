# Production environment for deploy/docker-compose.yml (plan §12).
# Copy to deploy/.env and fill in real secrets, deploy/.env is gitignored.

# Postgres (the postgres service reads these)
POSTGRES_USER=prosetype
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=prosetype

# App config (api + migrate + db-backup). Host is the compose service name.
DATABASE_URL=postgres://prosetype:change-me-to-a-long-random-string@postgres:5432/prosetype
PORT=3001
NODE_ENV=production

# Public origin. CORS_ORIGIN must match the scheme+host the browser uses;
# SITE_ADDRESS is what Caddy serves (a real domain gets automatic HTTPS).
CORS_ORIGIN=https://prosetype.example.com
SITE_ADDRESS=prosetype.example.com
